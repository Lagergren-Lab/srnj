import os

configfile: "config/config.yaml"

# Robust path detection - find project root by looking for key files
def find_project_root():
    """Find project root by looking for characteristic files/directories"""
    current_dir = os.path.dirname(os.path.abspath(workflow.snakefile))
    
    # Try different possible locations relative to Snakefile
    candidates = [
        os.path.join(current_dir, "../../../../"),      # Called from workflow/
        os.path.join(current_dir, "../../../"),        # Called from srnj_sconce2/
    ]
    
    for candidate in candidates:
        candidate = os.path.abspath(candidate)
        # Check for characteristic project files
        if (os.path.exists(os.path.join(candidate, "src")) and 
            os.path.exists(os.path.join(candidate, "scripts")) and
            os.path.exists(os.path.join(candidate, "README.md"))):
            return candidate
    
    # Fallback: assume we're in workflow/ subdirectory
    return os.path.abspath(os.path.join(current_dir, "../../../../"))

PROJECT_ROOT = find_project_root()
SCONCE2_DEFAULT = os.path.join(PROJECT_ROOT, "external", "sconce2", "sconce2")
SCONCE2_SCRIPTS_DEFAULT = os.path.join(PROJECT_ROOT, "external", "sconce2", "scripts")

SCONCE2 = config.get("SCONCE2_EXEC", SCONCE2_DEFAULT)
SCONCE2_SCRIPTS_PATH = config.get("SCONCE2_SCRIPTS", SCONCE2_SCRIPTS_DEFAULT)
RESULTS_DIR = config.get("RESULTS_DIR", "results")

# Verify paths exist and warn if not
if not os.path.exists(SCONCE2_SCRIPTS_PATH):
    print(f"Warning: SCONCE2 scripts directory not found at {SCONCE2_SCRIPTS_PATH}")
    print(f"Run: {PROJECT_ROOT}/scripts/setup_sconce2.sh to download SCONCE2")

SCRIPTS = "workflow/scripts/"
SOURCE_PATH = PROJECT_ROOT  # Use detected project root
# fix parameters
N_BINS_LIST = [1000]  # 1000 bins
N_CELLS_LIST = config.get("N_CELLS", [20])
N_CLONES_LIST = [6]
LAMDA_LIST = [2, 5]  # default
BIN_LENGTH = 1000000  # 1Mb bins
CN_LENGTH_MEAN = 10000000  # 10Mb average CNA length
N_CHROM_LIST = [10]  # 10 chromosomes
NORMAL_FRACTION = 0.2
REPEATS = config.get("REPEATS", 3)
# sconce2 params
SCONCE2_K = config.get("SCONCE2_K", 10)
KAPPA = config.get("KAPPA", 0)  # 0 = all pairs (default)
SEQ_ERROR_LIST = config.get("SEQ_ERROR", [0.02, 0.04])

wildcard_constraints:
    replicate=r"\d+",
    n_cells=r"\d+",
    n_bins=r"\d+",
    n_clones=r"\d+",
    lamda=r"\d+",
    e1=r"[\d.]+",
    e2=r"[\d.]+",
    n_chrom=r"\d+",
    seq_error=r"[\d.]+"


rule all:
    input:
        os.path.join(RESULTS_DIR, 'stats.csv'),
        os.path.join(RESULTS_DIR, 'plots.png'),
        os.path.join(RESULTS_DIR, 'cn_eval_plots.png'),
        os.path.join(RESULTS_DIR, 'sconce2_failures.txt')

rule simulate_cnasim:
    output:
        counts=os.path.join(RESULTS_DIR,"data","R{replicate}_N{n_cells}_M{n_bins}_K{n_clones}_L{lamda}_C{n_chrom}_E{seq_error}","cnasim_tmp","readcounts.tsv")
    conda: "envs/cnasim.yaml"
    params:
        replicate=lambda wc: int(wc.replicate),
        n_cells=lambda wc: round(int(wc.n_cells) / (1 - NORMAL_FRACTION)),  # tot cells including normal
        n_bins=lambda wc: int(wc.n_bins),
        n_clones=lambda wc: int(wc.n_clones),
        lamda=lambda wc: int(wc.lamda),
        n_chrom=lambda wc: int(wc.n_chrom),
        chrom_length=lambda wc: int(int(wc.n_bins) * BIN_LENGTH / int(wc.n_chrom)),
        normal_frac=lambda wc: NORMAL_FRACTION,
        seq_error=lambda wc: float(wc.seq_error),
        out_dir=subpath(output.counts,parent=True)
    shell: """
    cnasim -m 1 --use-uniform-coverage -n {params.n_cells} -c {params.n_clones} \
     -p1 {params.lamda} -o {params.out_dir} -N {params.n_chrom} -L {params.chrom_length} -n1 {params.normal_frac} \
     -B {BIN_LENGTH} --cn-length-mean {CN_LENGTH_MEAN} --cn-copy-param 0.8 -S {params.seq_error}
    """

rule prepare_anndata:
    input:
        counts=os.path.join(RESULTS_DIR,"data","R{replicate}_N{n_cells}_M{n_bins}_K{n_clones}_L{lamda}_C{n_chrom}_E{seq_error}","cnasim_tmp","readcounts.tsv")
    output: 
        adata=os.path.join(RESULTS_DIR,"data","R{replicate}_N{n_cells}_M{n_bins}_K{n_clones}_L{lamda}_C{n_chrom}_E{seq_error}","input.h5ad"),
        plot=os.path.join(RESULTS_DIR,"data","R{replicate}_N{n_cells}_M{n_bins}_K{n_clones}_L{lamda}_C{n_chrom}_E{seq_error}","input_X.png")
    params:
        cnasim_dir=subpath(input.counts,parent=True),
    conda: "envs/srnj.yaml"
    shell: """
    echo "Converting CNAsim output to anndata"
    PYTHONPATH={SOURCE_PATH}/src python {SCRIPTS}/cnasim2adata.py -i {params.cnasim_dir} -o {output.adata} --plot
    """

rule prepare_sconce2_input:
    input: os.path.join(RESULTS_DIR,"data","R{replicate}_N{n_cells}_M{n_bins}_K{n_clones}_L{lamda}_C{n_chrom}_E{seq_error}","input.h5ad")
    output:
        healthy_avg_bed=os.path.join(RESULTS_DIR,"data","R{replicate}_N{n_cells}_M{n_bins}_K{n_clones}_L{lamda}_C{n_chrom}_E{seq_error}","sconce2_input","healthyAvg.bed"),
        mean_var_coef_file=os.path.join(RESULTS_DIR,"data","R{replicate}_N{n_cells}_M{n_bins}_K{n_clones}_L{lamda}_C{n_chrom}_E{seq_error}","sconce2_input","meanVarCoefFile"),
        tumor_file_list=os.path.join(RESULTS_DIR,"data","R{replicate}_N{n_cells}_M{n_bins}_K{n_clones}_L{lamda}_C{n_chrom}_E{seq_error}","sconce2_input","tumorFileList")
    params:
        output_dir=subpath(output.healthy_avg_bed,parent=True),
        script_path=SCONCE2_SCRIPTS_PATH,
        normal_obs_name="normal"
    conda: "envs/srnj.yaml"
    shell: """
    echo "Preparing SCONCE2 input files"
    PYTHONPATH={SOURCE_PATH}/src python {SCRIPTS}/prepare_sconce2_input.py \
        --input {input} \
        --output {params.output_dir} \
        --normal-obs-name {params.normal_obs_name} \
        --script-path {params.script_path}
    """

rule run_sconce2:
    input:
        healthy_avg_bed=os.path.join(RESULTS_DIR,"data","R{replicate}_N{n_cells}_M{n_bins}_K{n_clones}_L{lamda}_C{n_chrom}_E{seq_error}","sconce2_input","healthyAvg.bed"),
        mean_var_coef_file=os.path.join(RESULTS_DIR,"data","R{replicate}_N{n_cells}_M{n_bins}_K{n_clones}_L{lamda}_C{n_chrom}_E{seq_error}","sconce2_input","meanVarCoefFile"),
        tumor_file_list=os.path.join(RESULTS_DIR,"data","R{replicate}_N{n_cells}_M{n_bins}_K{n_clones}_L{lamda}_C{n_chrom}_E{seq_error}","sconce2_input","tumorFileList")
    output:
        # output marker for SCONCE2 completion
        done=os.path.join(RESULTS_DIR,"data","R{replicate}_N{n_cells}_M{n_bins}_K{n_clones}_L{lamda}_C{n_chrom}_E{seq_error}","sconce2_output","sconce2.done"),
        hmm=os.path.join(RESULTS_DIR,"data","R{replicate}_N{n_cells}_M{n_bins}_K{n_clones}_L{lamda}_C{n_chrom}_E{seq_error}","sconce2_output","model.hmm")
    benchmark: os.path.join(RESULTS_DIR,"data","R{replicate}_N{n_cells}_M{n_bins}_K{n_clones}_L{lamda}_C{n_chrom}_E{seq_error}","benchmark_run_sconce2.tsv")
    params:
        output_dir=subpath(output.done,parent=True),
        k=SCONCE2_K
    threads: 8
    shell: """
    # Check if SCONCE2 binary exists and is executable
    if [ ! -x "{SCONCE2}" ]; then
        echo "ERROR: SCONCE2 binary not found or not executable at {SCONCE2}" >&2
        echo "Please install SCONCE2 or update SCONCE2_EXEC in config" >&2
        echo "See README.md for installation instructions" >&2
        exit 1
    fi
    
    echo "Running SCONCE2 from: {SCONCE2}"
    mkdir -p {params.output_dir}
    {SCONCE2} -d {input.healthy_avg_bed} -t {input.tumor_file_list} --meanVarCoefFile {input.mean_var_coef_file} -k {params.k} -o {params.output_dir}/model --saveSconce --summarizeAll --numPairsToSummarize {KAPPA} -j {threads} --sconceEstimatesPath {params.output_dir}/ --pairedEstimatesPath {params.output_dir}/ > {params.output_dir}/sconce2.log 2> {params.output_dir}/sconce2.err && (echo "success" > {output.done}) || (echo "failure" > {output.done}; touch {output.hmm})
    """

rule prepare_medicc2_input:
    input:
        sconce2_done=os.path.join(RESULTS_DIR,"data","R{replicate}_N{n_cells}_M{n_bins}_K{n_clones}_L{lamda}_C{n_chrom}_E{seq_error}","sconce2_output","sconce2.done")
    output:
        medicc2_input=os.path.join(RESULTS_DIR,"data","R{replicate}_N{n_cells}_M{n_bins}_K{n_clones}_L{lamda}_C{n_chrom}_E{seq_error}","medicc2_input","med_input.tsv")
    params:
        sconce2_dir=subpath(input.sconce2_done,parent=True),
    conda: "envs/srnj.yaml"
    shell: """
    # Check if sconce2_done contains "failure", skip preparing medicc2 input and write empty file
    if grep -q "failure" {input.sconce2_done}; then
        echo "SCONCE2 failed, skipping MEDICC2 input preparation and writing empty file"
        mkdir -p $(dirname {output.medicc2_input})
        touch {output.medicc2_input}
        exit 0
    fi
    echo "Preparing MEDICC2 input from SCONCE2 output"
    PYTHONPATH={SOURCE_PATH}/src python {SCRIPTS}/prepare_medicc2_input.py \
        --input {params.sconce2_dir} \
        --output {output.medicc2_input}
    """

rule run_medicc2:
    # use sconce2 cn profiles as input to medicc2
    input:
        medicc2_input=os.path.join(RESULTS_DIR,"data","R{replicate}_N{n_cells}_M{n_bins}_K{n_clones}_L{lamda}_C{n_chrom}_E{seq_error}","medicc2_input","med_input.tsv")
    output:
        distmat=os.path.join(RESULTS_DIR,"data","R{replicate}_N{n_cells}_M{n_bins}_K{n_clones}_L{lamda}_C{n_chrom}_E{seq_error}","medicc2_output","med_input_pairwise_distances.tsv")
    benchmark: os.path.join(RESULTS_DIR,"data","R{replicate}_N{n_cells}_M{n_bins}_K{n_clones}_L{lamda}_C{n_chrom}_E{seq_error}","benchmark_run_medicc2.tsv")
    params:
        output_dir=subpath(output.distmat,parent=True)
    threads: 8
    conda: "envs/medicc2.yaml"
    shell: """
    # if medicc2_input is empty, skip running medicc2 and write empty distance matrix
    if [ ! -s {input.medicc2_input} ]; then
        echo "MEDICC2 input file is empty, skipping MEDICC2 and writing empty distance matrix"
        mkdir -p $(dirname {output.distmat})
        touch {output.distmat}
        exit 0
    fi
    echo "Running MEDICC2"
    medicc2 {input.medicc2_input} {params.output_dir} -j {threads} --plot auto --no-wgd --input-allele-columns 'total_cn' --total-copy-numbers
    """

rule run_evaluation:
    input:
        med_dist=os.path.join(RESULTS_DIR,"data","R{replicate}_N{n_cells}_M{n_bins}_K{n_clones}_L{lamda}_C{n_chrom}_E{seq_error}","medicc2_output","med_input_pairwise_distances.tsv"),
        sconce2_hmm=os.path.join(RESULTS_DIR,"data","R{replicate}_N{n_cells}_M{n_bins}_K{n_clones}_L{lamda}_C{n_chrom}_E{seq_error}","sconce2_output","model.hmm"),
        input_ad=os.path.join(RESULTS_DIR,"data","R{replicate}_N{n_cells}_M{n_bins}_K{n_clones}_L{lamda}_C{n_chrom}_E{seq_error}","input.h5ad")
    output: os.path.join(RESULTS_DIR,"data","R{replicate}_N{n_cells}_M{n_bins}_K{n_clones}_L{lamda}_C{n_chrom}_E{seq_error}", "results.csv")
    conda: "envs/srnj.yaml"
    shell: """
    echo "Evaluating results"
    PYTHONPATH={SOURCE_PATH}/src python {SCRIPTS}/evaluate_sconce2_medicc2.py \
        --medicc2-dist {input.med_dist} \
        --sconce2-hmm {input.sconce2_hmm} \
        --input-ad {input.input_ad} \
        --output {output}
    """

rule evaluate_sconce2_cn:
    input:
