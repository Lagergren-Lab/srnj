        input_ad=os.path.join(RESULTS_DIR,"data","R{replicate}_N{n_cells}_M{n_bins}_K{n_clones}_L{lamda}_C{n_chrom}_E{seq_error}","input.h5ad")
    output:
        os.path.join(RESULTS_DIR,"data","R{replicate}_N{n_cells}_M{n_bins}_K{n_clones}_L{lamda}_C{n_chrom}_E{seq_error}", "cn_eval.csv")
    conda: "envs/srnj.yaml"
    shell: """
    echo "Evaluating SCONCE2 CN calls"
    PYTHONPATH={SOURCE_PATH}/src python {SCRIPTS}/evaluate_sconce2_cn.py \
        --input-ad {input.input_ad} \
        --sconce2-done {input.sconce2done} \
        --output {output} \
        -k {SCONCE2_K}
    """

rule summarize_sconce2_failures:
    input:
        sconce2_done=expand( os.path.join(RESULTS_DIR,"data","R{replicate}_N{n_cells}_M{n_bins}_K{n_clones}_L{lamda}_C{n_chrom}_E{seq_error}","sconce2_output","sconce2.done"),
            replicate=range(REPEATS),n_cells=N_CELLS_LIST,n_bins=N_BINS_LIST,n_clones=N_CLONES_LIST,lamda=LAMDA_LIST,n_chrom=N_CHROM_LIST,seq_error=SEQ_ERROR_LIST
        )
    output: os.path.join(RESULTS_DIR, "sconce2_failures.txt")
    conda: "envs/srnj.yaml"
    shell: """
    echo "Analyzing SCONCE2 failures"
    PYTHONPATH={SOURCE_PATH}/src python {SCRIPTS}/summarize_sconce2_failures.py {input.sconce2_done} >| {output}
    """

rule summarize_cn_eval:
    input:
        cn_metrics=expand(os.path.join(RESULTS_DIR,"data","R{replicate}_N{n_cells}_M{n_bins}_K{n_clones}_L{lamda}_C{n_chrom}_E{seq_error}","cn_eval.csv"),
            replicate=range(REPEATS),n_cells=N_CELLS_LIST,n_bins=N_BINS_LIST,n_clones=N_CLONES_LIST,lamda=LAMDA_LIST,n_chrom=N_CHROM_LIST,seq_error=SEQ_ERROR_LIST
        )
    output: os.path.join(RESULTS_DIR,"cn_eval_summary.csv")
    conda: "envs/srnj.yaml"
    shell: """
    echo "Summarizing CN evaluation results"
    echo "seed,n_cells,n_bins,n_clones,lamda,n_chrom,seq_error,$(head -n 1 {input.cn_metrics[0]})" > {output}
    for f in {input.cn_metrics}; do
        d=$(basename $(dirname $f))
        IFS="_" read r n m k l c e <<< "${{d#R}}"
        e=${{e#E}}
        awk -F',' -v OFS=',' -v r=$r -v n=$n -v m=$m -v k=$k -v l=$l -v c=$c -v e=$e \
            'NR>1 {{print r,n,m,k,l,c,e,$0}}' $f >> {output}
    done
    """

rule summarize_tree_metrics:
    input:
        tree_metrics=expand(os.path.join(RESULTS_DIR,"data","R{replicate}_N{n_cells}_M{n_bins}_K{n_clones}_L{lamda}_C{n_chrom}_E{seq_error}", "results.csv"),
            replicate=range(REPEATS),n_cells=N_CELLS_LIST,n_bins=N_BINS_LIST,n_clones=N_CLONES_LIST,lamda=LAMDA_LIST,n_chrom=N_CHROM_LIST,seq_error=SEQ_ERROR_LIST
        )
    output:os.path.join(RESULTS_DIR,"stats.csv")
    conda: "envs/srnj.yaml"
    shell: r"""
    echo "Summarizing results into a single CSV file"
    echo "seed,n_cells,n_bins,n_clones,lamda,n_chrom,seq_error,$(head -n 1 {input.tree_metrics[0]})" > {output}
    for f in {input.tree_metrics}; do
      d=$(basename "$(dirname "$f")")
      IFS="_" read r n m k l c e <<< "${{d#R}}"
      n=${{n#N}}; m=${{m#M}}; k=${{k#K}}; l=${{l#L}}; c=${{c#C}}; e=${{e#E}}

      awk -F'\t' -v OFS=',' -v r=$r -v n=$n -v m=$m -v k=$k -v l=$l -v c=$c -v e=$e '
        NR>1 {{
          printf "%s,%s,%s,%s,%s,%s,%s", r,n,m,k,l,c,e
          for (i=1;i<=NF;i++) printf "%s%s", OFS, $i
          printf "\n"
        }}' "$f" >> {output}
    done
    """


rule plot_tree_metrics:
    input: os.path.join(RESULTS_DIR,"stats.csv")
    output: os.path.join(RESULTS_DIR,"plots.png")
    shell: """
    module load R/4.4 2>/dev/null || true
    Rscript {SCRIPTS}/plot_results.R {input} {output}
    """

